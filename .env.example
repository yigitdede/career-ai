# CareerTalent AI — Docker Compose ortam değişkenleri
# Kopyala: cp .env.example .env

# ── FastAPI (backend/) ──────────────────────────────────────
APP_NAME=CareerTalent AI
APP_ENV=development
DEBUG=true
SECRET_KEY=dev-secret-change-me
DATABASE_URL=postgresql+psycopg2://careertalent:careertalent@db:5432/careertalent
REDIS_URL=redis://redis:6379/0
AI_PROVIDER=gemini
AI_TEMPERATURE=0.3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
JWT_SECRET_KEY=jwt-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
DEFAULT_COHORT_NAME=YZTA Grup 92

# ── Laravel (frontend/) — frontend/.env içinde ayrıca tanımlayın ──
# CAREERTALENT_API_URL=http://localhost:8000
